# REQUIRED - OpenAI API key for GPT-4o diagnosis and code repair.
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# REQUIRED - Slack webhook for incident notifications.
# Get it at: https://api.slack.com/apps -> Create App -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# OPTIONAL - Redis connection.
REDIS_URL=redis://localhost:6379

# OPTIONAL - App URLs.
APP_URL=http://localhost:8000
SANDBOX_URL=http://localhost:9000

# OPTIONAL - Confidence threshold.
CONFIDENCE_THRESHOLD=0.60

# OPTIONAL - FMG fast-path similarity threshold.
FMG_FAST_PATH_THRESHOLD=0.87

# OPTIONAL - Scout polling interval in seconds.
SCOUT_POLL_INTERVAL=5

# OPTIONAL - Consensus window in seconds.
CONSENSUS_WINDOW=60

ANTHROPIC_API_KEY=your-anthropic-api-key-here
